# Copy to .env.local for local dev.
# For production, set these in Vercel → Settings → Environment Variables.

# Anthropic — optional. Without it, the hello-claude page shows a fallback message.
ANTHROPIC_API_KEY=

# GitHub — optional. Without it, the /submit form stores ideas in memory only.
# When set, the form creates real GitHub Issues.
GITHUB_TOKEN=
GITHUB_OWNER=Cjmm67
GITHUB_REPO=ai-sandbox-test
